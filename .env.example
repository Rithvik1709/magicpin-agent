# Railway will auto-assign PORT
PORT=8080

# LLM Configuration
# The bot works WITHOUT an LLM (deterministic fallback) but scores higher with one.
# Set LLM_PROVIDER and LLM_API_KEY for LLM-powered composition.

LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini

# Supported providers:
# LLM_PROVIDER=openai       LLM_MODEL=gpt-4o-mini (default)
# LLM_PROVIDER=anthropic    LLM_MODEL=claude-3-5-sonnet-20241022 (default)
# LLM_PROVIDER=gemini       LLM_MODEL=gemini-1.5-flash (default)
# LLM_PROVIDER=deepseek     LLM_MODEL=deepseek-chat (default)
# LLM_PROVIDER=groq         LLM_MODEL=llama-3.1-70b-versatile (default) — FREE tier available
